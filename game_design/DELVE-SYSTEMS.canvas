		{"id":"h1","type":"text","text":"**Base (free)**\nrotation plays normal floors · idle gold trickle offline (8h)","x":340,"y":1550,"width":360,"height":150},
		{"id":"h2","type":"text","text":"**T1 Auto-continue**\nto depth X\n(unlock: first boss)","x":740,"y":1550,"width":300,"height":150},
		{"id":"h6","type":"text","text":"**T5 Capacity**\nmore runs / longer window (repeatable)","x":1460,"y":1780,"width":280,"height":150},
		{"id":"h5","type":"text","text":"**T4 OFFLINE EXPEDITIONS** (~L45)\npolicy (start · extract-at · consumables) → server-simulated REAL runs, real deaths → welcome-back report","x":840,"y":1900,"width":520,"height":190,"color":"4"},
		{"id":"g1","type":"text","text":"**Every run counts**\nfrontier damage = depths + 3×boss kills (extract OR death; soft cap best-3/day)","x":670,"y":-720,"width":400,"height":160},
		{"id":"g4","type":"text","text":"**DAILY DELVE**\nshared seed · ONE attempt · depth-1 start · real hero · per-sub board (ties: less dmg taken) · podium flair","x":1530,"y":-720,"width":400,"height":180,"color":"3"},
		{"id":"g5","type":"text","text":"**The feed**\nlive post preview (Terror HP in-feed) · ledger comment shares · daily foreman report · full mod opt-outs","x":1600,"y":-490,"width":400,"height":180},
		{"id":"g6","type":"text","text":"**Guild codex %** · sub-vs-sub ladder (later, cross-install)","x":1600,"y":-100,"width":400,"height":140},
		{"id":"g2","type":"text","text":"**The TERROR** (HP ∝ active delvers, min 3)\nFELLED → sub-wide buff 3d + celebration post + next Terror + checkpoint energy","x":960,"y":-440,"width":400,"height":170,"color":"1"},
		{"id":"g3","type":"text","text":"**Season** (~4wk, 8-12 Terrors)\nfinale win/loss → boards reset, hero persists, cosmetic stamps, next season's modifier","x":960,"y":-100,"width":400,"height":180},
		{"id":"f1","type":"text","text":"**Pick a base class**\nSquire · Archer · Apprentice (all 3 at creation)","x":395,"y":-1960,"width":330,"height":140},
		{"id":"f2","type":"text","text":"**L25 gate → TEMPLE**\nquest tasks + retryable trial boss → promote (stage 2 kit + options)","x":395,"y":-1680,"width":330,"height":170,"color":"2"},
		{"id":"f3","type":"text","text":"**L45 gate → trial**\n→ final form (stage 3 + ultimate slot)","x":395,"y":-1480,"width":330,"height":140},
		{"id":"f7","type":"text","text":"**Hidden chains (post-launch)**\nrelic crafting (fragments) · secret deeds (un-dataminable) · community unlocks (frontier milestone opens it for the whole sub)","x":1200,"y":-1895,"width":730,"height":150,"color":"6"},
		{"id":"f4","type":"text","text":"**L70 capstone TRIAL**\n(harder) → **MASTERY**","x":870,"y":-1550,"width":330,"height":140,"color":"1"},
		{"id":"f5","type":"text","text":"**Mastery grants**\n+2.5% account stats · class saved & playable forever · inherited ability · title/skin","x":670,"y":-1240,"width":330,"height":190},
		{"id":"f6","type":"text","text":"**Restart next chain** (faster: checkpoints + twink gear + bonuses)\nor keep playing mastered — gear/ladder only, no post-cap XP","x":1500,"y":-1550,"width":330,"height":190},
		{"id":"a6","type":"text","text":"**Event floor ~1/8**\nShrine boon · Gamble altar (HP→chest) · Cache (pick 1 of 2) · Lore","x":-2340,"y":-2500,"width":340,"height":150,"color":"3"},
