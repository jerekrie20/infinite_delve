		{"id":"a1","type":"text","text":"**Torchrest** (hub)\nForge · Market · Lift · Temple · Guildhall · Trophy Hall","x":-3380,"y":-2190,"width":300,"height":150,"color":"4"},
		{"id":"a9","type":"text","text":"**EXTRACT**\nbank EVERYTHING\n(haul → equip/stash, gold, XP)\nboss felled = checkpoint unlocked","x":-3380,"y":-1850,"width":300,"height":160,"color":"4"},
		{"id":"a2","type":"text","text":"**Pick checkpoint**\nany felled 10-boss floor (11, 21, 31…) or depth 1","x":-3000,"y":-2190,"width":300,"height":150},
		{"id":"a3","type":"text","text":"**Floor spawns**\npack of 1-3 in rows\n(one floor budget split)","x":-2640,"y":-2190,"width":300,"height":150},
		{"id":"a7","type":"text","text":"**Every 5th floor**\nmini-boss → pause:\nCONTINUE or EXTRACT?\n(flee = between fights only)","x":-1920,"y":-1860,"width":300,"height":160,"color":"2"},
		{"id":"a4","type":"text","text":"**Rotation fights**\nauto-battle; manual casts interleave anytime","x":-2140,"y":-2220,"width":240,"height":150},
		{"id":"title","type":"text","text":"# 🧬 DELVE — SYSTEMS MAP\nHow the mechanics actually WORK and feed each other. Cards = mechanics · arrows = flow.\n(Companion: DELVE-MAP.canvas = the doc atlas · numbers ⚙ live in FORMULAS.md)","x":-3490,"y":-2780,"width":1700,"height":180,"color":"3"},
		{"id":"b1","type":"text","text":"**100ms clock**\nseeded Rng → same seed = same fight (daily · sim · anti-cheat)","x":-3180,"y":-910,"width":340,"height":140,"color":"5"},
		{"id":"b2","type":"text","text":"**Per-entity timers**\ninterval ÷ (1 + attackSpeed%)\nSquire 2.0s · Archer 1.5s · Mage 3.0s","x":-3180,"y":-680,"width":340,"height":140},
		{"id":"b3","type":"text","text":"**Hero acts**\nslot 1 = basic attack (free), OR rotation fires highest-priority slot 2-5 that's ready + affordable","x":-3180,"y":-480,"width":340,"height":180},
		{"id":"b4","type":"text","text":"**Damage**\nATK × (1−DEF%) × ±5%\ncrit = base × (1+inc%) · ×critMult","x":-2820,"y":-910,"width":340,"height":140},
		{"id":"b5","type":"text","text":"**Hooks (both sides)**\nonAttack · onCrit · onDeal/TakeDamage · onKill · perTick — 29 handlers","x":-2440,"y":-750,"width":340,"height":140},
		{"id":"b6","type":"text","text":"**16 statuses** (1s tick)\nDoTs (Poison/Burn/Bleed) · Stun · StatMods (Slow/Mark/Rage…) · Shield · Shock\nelement tags → theme affinity ±25% · statusResist roll","x":-2650,"y":-520,"width":340,"height":180,"color":"6"},
		{"id":"b7","type":"text","text":"**Boss signatures**\nevery 10-15s: 1-beat WIND-UP → big move.\nCounterplay = drop Stun/Fortify into the wind-up","x":-2480,"y":-180,"width":340,"height":150,"color":"1"},
		{"id":"b8","type":"text","text":"**Targeting types**\nfront / all / back-row / random\n(kill the back-row support first?)","x":-3180,"y":-180,"width":340,"height":150},
		{"id":"c1","type":"text","text":"**1 · Class + stage**\nbase stats, attack interval, mana model","x":-1850,"y":-835,"width":340,"height":130},
		{"id":"c2","type":"text","text":"**2 · Level** 1→70\n+HP/+ATK per level","x":-1850,"y":-655,"width":340,"height":120},
		{"id":"c3","type":"text","text":"**3 · Gear**\n33 base families × affixes (50 stats) · 2H = both hands ×1.6 budget · level reqs","x":-1850,"y":-485,"width":340,"height":150},
		{"id":"c4","type":"text","text":"**4 · Sets (6) + Uniques (12)**\nthe build-defining spikes","x":-1850,"y":-285,"width":340,"height":130},
		{"id":"c5","type":"text","text":"**5 · Passive slots**\nclass pools, unlock by level","x":-1850,"y":-105,"width":340,"height":130},
		{"id":"c6","type":"text","text":"**6 · Account layer**\n+2.5% per MASTERY · one inherited ability","x":-1850,"y":75,"width":340,"height":140,"color":"1"},
		{"id":"c7","type":"text","text":"**7 · Per-run flex**\nconsumables + shrine boons","x":-1850,"y":265,"width":340,"height":130},
		{"id":"c9","type":"text","text":"**THE BUILD**\n5 slots × 4 options + rotation ORDER + targeting\n9 archetypes must stay viable (build-theory)","x":-1850,"y":700,"width":340,"height":190,"color":"6"},
		{"id":"c8","type":"text","text":"**deriveStats fold**\n(base + Σflat) × (1 + Σpct/100), capped\n→ your Combatant","x":-1850,"y":485,"width":340,"height":170,"color":"6"},
		{"id":"a10","type":"text","text":"**DIE**\nlose all unbanked since start\n→ death recap card (killer, last hits, what was lost)","x":-2790,"y":-1960,"width":300,"height":160,"color":"1"},
		{"id":"a5","type":"text","text":"**Kill**\nloot orb + gold · heal 45% maxHp · depth +1","x":-1720,"y":-2220,"width":300,"height":150},
		{"id":"d8","type":"text","text":"**Boss kill → 1 theme fragment**\n~35 = craft a CHOSEN unique (visible pity bar)","x":-1230,"y":1070,"width":340,"height":140,"color":"1"},
		{"id":"d1","type":"text","text":"**Drop roll** 20%/kill (swarm ×2)","x":-1230,"y":365,"width":340,"height":130},
		{"id":"d2","type":"text","text":"**What drops?**\nUNIQUE 1-5% → SET 5-15% → else base + depth-weighted rarity + affixes (0-4 by rarity)","x":-1360,"y":590,"width":340,"height":170},
		{"id":"d3","type":"text","text":"**Loot as light**\nglowing orb in rarity color → fly-to-bag · UNBANKED until extract","x":-1360,"y":830,"width":340,"height":140,"color":"3"},
		{"id":"d6","type":"text","text":"**THE FORGE**\nreroll values · reroll one affix · rarity upgrade · pity unique · relics (hidden chains)\ncosts gold + essences","x":-890,"y":760,"width":340,"height":190,"color":"2"},
		{"id":"d4","type":"text","text":"**On extract**\nsmart auto-equip (never breaks sets/uniques silently) · rest → stash (pages)","x":-830,"y":320,"width":340,"height":150},
		{"id":"d5","type":"text","text":"**Salvage** (replaces selling)\n→ gold + rarity ESSENCES\nloot filter auto-salvages junk (free QoL)","x":-830,"y":540,"width":340,"height":150},
		{"id":"d7","type":"text","text":"**Codex: collection**\nevery item found/unfound (silhouettes = visible chases)","x":-720,"y":1280,"width":340,"height":140},
		{"id":"e1","type":"text","text":"**Faucets**\nkill gold (EV, server-computed) · idle trickle (8h cap) · expeditions · salvage","x":-190,"y":430,"width":380,"height":160},
		{"id":"e5","type":"text","text":"**REAL MONEY = cosmetics/status ONLY**\nTorchrest decorations · flair · community supply drop (credited gift)\nNEVER gold, automation, gear, power — D2, non-negotiable","x":-190,"y":1100,"width":800,"height":160,"color":"1"},
		{"id":"e4","type":"text","text":"**Essences** ×5 tiers\n4:1 down-convert, never up","x":190,"y":820,"width":380,"height":130},
		{"id":"e3","type":"text","text":"**Sinks (by account age)**\nconsumables → automation tiers → stash pages → crafting (infinite)","x":315,"y":400,"width":380,"height":190},
		{"id":"e2","type":"text","text":"**GOLD**\n(single currency)","x":-190,"y":830,"width":280,"height":130,"color":"2"},
